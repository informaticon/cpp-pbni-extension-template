{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) Attach",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${input:GetPowerBuilderPID}"
        }
    ],
    "inputs": [
        {
            // this needs the "augustocdias.tasks-shell-input" vscode extension
            "id": "GetPowerBuilderPID",
            "type": "command",
            "command": "shellCommand.execute",
            "args": {
                "command": "powershell",
                "commandArgs": [
                    "-Command",
                    "(Get-Process -Name pb2*0).ID"
                ],
                "useSingleResult": true
            }
        }
    ]
}